{
  "name": "@hosaka/crate",
  "version": "0.1.0",
  "description": "Official typed TypeScript client for the crate public API.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "generate": "node scripts/generate-types.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:exports": "attw --pack .",
    "check:staleness": "node scripts/check-spec-staleness.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@types/node": "^22.10.2",
    "openapi-typescript": "7.13.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "5.7.3",
    "undici": "^6.21.0",
    "vitest": "^2.1.8"
  }
}
