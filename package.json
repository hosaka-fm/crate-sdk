{
  "name": "@hosaka-fm/crate",
  "version": "1.14.0",
  "description": "Official typed TypeScript client for the crate public API.",
  "keywords": [
    "crate",
    "hosaka",
    "music",
    "music-catalogue",
    "music-metadata",
    "discography",
    "bandcamp",
    "discogs",
    "musicbrainz",
    "api-client",
    "rest-client",
    "sdk",
    "typescript",
    "ai-agent",
    "dossier",
    "festival",
    "tastemaker"
  ],
  "license": "MIT",
  "author": "Hosaka FM",
  "homepage": "https://github.com/hosaka-fm/crate-sdk#readme",
  "bugs": {
    "url": "https://github.com/hosaka-fm/crate-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hosaka-fm/crate-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "generate": "node scripts/generate-types.mjs",
    "spec:vendor": "node scripts/vendor-spec.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:exports": "attw --pack .",
    "check:staleness": "node scripts/check-spec-staleness.mjs",
    "docs:api": "npx --yes typedoc",
    "docs:surface": "node scripts/extract-surface.mjs",
    "docs:gen": "node scripts/gen-docs.mjs",
    "docs:build": "npm run build && npm run docs:surface && npm run docs:gen && prettier --write README.md",
    "docs:check": "npm run docs:build && { [ -z \"$(git status --porcelain -- README.md meta explorer)\" ] || { echo 'docs are stale — run: npm run docs:build'; git status --porcelain -- README.md meta explorer; exit 1; }; }",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@types/node": "^22.10.2",
    "openapi-typescript": "7.13.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "5.7.3",
    "undici": "^6.21.0",
    "vitest": "^2.1.8"
  }
}
