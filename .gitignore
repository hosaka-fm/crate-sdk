# Node / build
node_modules/
dist/
docs/api/
coverage/
pack.json
*.tsbuildinfo
.DS_Store
*.tgz

# Docs site (Astro Starlight) — build-only (node_modules/ + dist/ already covered above)
.astro/
# Generated docs content (single-source: regenerated each build by site/scripts/sync-content.mjs)
site/src/content/docs/guides/
site/src/content/docs/sdk/
site/src/content/docs/changelog.md
site/src/content/docs/concepts/index.md
site/public/explorer/
site/spec/

# Run-mode ephemeral state (recovery only; not history)
.run/

# LOA LOCAL-ONLY — framework is mounted as a submodule LOCALLY but NEVER tracked
# on this (public) repo. These were all excluded by the clean-room export; keeping
# them ignored prevents an accidental `git add -A` from leaking the framework — or
# the upstream submodule URL in .gitmodules — into the public tree.
# Update loa via: cd .loa && git pull origin main   (then re-run mount --reconcile)
/.loa/
/.gitmodules
/.loa-version.json
/.loa.config.yaml
/.claude/
/grimoires/
/.beads/
/CLAUDE.md
/.github/workflows/post-merge.yml
